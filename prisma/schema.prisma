// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin User
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Services/Layanan
model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String?  // Icon name or URL
  detail      String?  // Detailed description
  image       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Portfolio/Projects
model Portfolio {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  category    String   // e.g., "website", "mobile", "ecommerce"
  link        String?
  technologies String? // JSON string or comma-separated
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Blog Articles
model BlogArticle {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String?
  image     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contact Messages
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  read      Boolean  @default(false)
  replied   Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Global site settings (singleton record)
model SiteSetting {
  id                    String   @id @default(cuid())
  singletonKey          String   @unique @default("default")
  siteName              String   @default("ASDEV Solution Technology")
  siteShortName         String   @default("ASDEV")
  siteTagline           String   @default("Solusi teknologi terpercaya untuk transformasi digital bisnis")
  legalCompanyName      String   @default("CV Asdev Solusi Teknologi")
  logoLightUrl          String   @default("/brand/asdev-logo-light.png")
  logoDarkUrl           String   @default("/brand/asdev-logo-dark.png")
  supportEmail          String   @default("info@asdev.id")
  phoneDisplay          String   @default("+62 812-3456-7890")
  whatsappNumber        String   @default("6281234567890")
  addressText           String   @default("Indonesia")
  businessHours         String   @default("Senin - Jumat, 09:00 - 18:00 WIB")
  websiteUrl            String   @default("https://asdev-digital.com")
  seoDefaultDescription String   @default("Kami menyediakan layanan website development, mobile app, sistem informasi, dan UI/UX design untuk transformasi digital bisnis Anda.")
  facebookUrl           String?
  instagramUrl          String?
  linkedinUrl           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
